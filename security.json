{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["helpers:pinGitHubActionDigests"],
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "description": "Delay GitHub Actions updates for supply chain security",
      "matchManagers": ["github-actions"],
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Disable minimum release age checks for Rstack packages",
      "matchPackageNames": [
        "@rspack/*",
        "@rsbuild/*",
        "@rslib/*",
        "@rspress/*",
        "@rstest/*",
        "@rsdoctor/*",
        "@rslint/*",
        "@swc/*",
        "rsbuild-plugin-*"
      ],
      "minimumReleaseAge": null
    }
  ]
}
