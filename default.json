{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly",
    "group:allNonMajor",
    "github>rstackjs/renovate:security",
    "github>rstackjs/renovate:disableNodeEngines",
    "github>rstackjs/renovate:disablePeerDependencies"
  ],
  "ignorePaths": ["**/node_modules/**"],
  "timezone": "Asia/Shanghai",
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest", "pinDigest"],
      "automerge": true
    },
    {
      "matchPackageNames": [
        "@rspack/core",
        "@rspack/cli",
        "@rspack/browser",
        "@rsbuild/core"
      ],
      "allowedVersions": "!/-canary/"
    },
    { "matchUpdateTypes": ["minor", "patch"], "automerge": true }
  ]
}
